  230          unsigned int Ultrasonic_GetDistance(void) 
  231          {
  232   1          unsigned int Distance_mm = 0;
  233   1          TRIG = 0;
  234   1          _nop_(); _nop_(); _nop_(); _nop_();
  235   1          _nop_(); _nop_(); _nop_(); _nop_();
  236   1          TRIG = 1;
  237   1          _nop_(); _nop_(); _nop_(); _nop_();    // 等价大约10us
  238   1          _nop_(); _nop_(); _nop_(); _nop_();
  239   1          _nop_(); _nop_(); _nop_(); _nop_();
  240   1          TRIG = 0;
  241   1      
  242   1          // 等待 ECHO 高电平开始
  243   1          while (!ECHO);
  244   1          
  245   1          // 开始计时
  246   1          time_us = 0;
  247   1          measuring = 1;
  248   1      
  249   1          // 等待 ECHO 拉低（结束）
  250   1          while (ECHO);
  251   1      
  252   1          measuring = 0;
  253   1          if(time_us/100<38)                  //判断是否小于38毫秒，大于38毫秒的就是超时，直接调到下面返回0
