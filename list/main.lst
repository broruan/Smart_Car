  224          /*
  225           * 作用：触发HC-SR04超声波模块并计算障碍物距离。
  226           * 参数：无。
  227           * 返回：距离值，单位mm；超时或无有效回波时返回0。
  228           */
  229          unsigned int Ultrasonic_GetDistance(void) 
  230          {
  231   1          unsigned int Distance_mm = 0;
  232   1          TRIG = 0;
  233   1          _nop_(); _nop_(); _nop_(); _nop_();
  234   1          _nop_(); _nop_(); _nop_(); _nop_();
  235   1          TRIG = 1;
  236   1          _nop_(); _nop_(); _nop_(); _nop_();    // 等价大约10us
  237   1          _nop_(); _nop_(); _nop_(); _nop_();
  238   1          _nop_(); _nop_(); _nop_(); _nop_();
  239   1          TRIG = 0;
  240   1      
  241   1          // 等待 ECHO 高电平开始
  242   1          while (!ECHO);
  243   1          
  244   1          // 开始计时
  245   1          time_us = 0;
  246   1          measuring = 1;
  247   1      
  248   1          // 等待 ECHO 拉低（结束）
  249   1          while (ECHO);
  250   1      
  251   1          measuring = 0;
  252   1          if(time_us/100<38)                  //判断是否小于38毫秒，大于38毫秒的就是超时，直接调到下面返回0
  253   1          {
C251 COMPILER V5.60.0,  main                                                               14/06/26  11:33:04  PAGE 5   

  254   2            Distance_mm=(time_us*346)/100;            //计算距离，25°C空气中的音速为346m/s   因为上面的time_end的单位是
             -10微秒，所以要得出单位为毫米的距离结果，还得除以100
  255   2          }
  256   1          return Distance_mm;
  257   1      }
