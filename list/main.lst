  222          /*
  223           * 作用：触发HC-SR04超声波模块并计算障碍物距离。
  224           * 参数：无。
  225           * 返回：距离值，单位mm；超时或无有效回波时返回0。
  226           */
  227          unsigned int Ultrasonic_GetDistance(void) 
  228          {
  229   1          unsigned int Distance_mm = 0;
  230   1          TRIG = 0;
  231   1          _nop_(); _nop_(); _nop_(); _nop_();
  232   1          _nop_(); _nop_(); _nop_(); _nop_();
  233   1          TRIG = 1;
  234   1          _nop_(); _nop_(); _nop_(); _nop_();    // 等价大约10us
  235   1          _nop_(); _nop_(); _nop_(); _nop_();
  236   1          _nop_(); _nop_(); _nop_(); _nop_();
  237   1          TRIG = 0;
  238   1      
  239   1          // 等待 ECHO 高电平开始
  240   1          while (!ECHO);
  241   1          
  242   1          // 开始计时
  243   1          time_us = 0;
  244   1          measuring = 1;
  245   1      
  246   1          // 等待 ECHO 拉低（结束）
  247   1          while (ECHO);
  248   1      
  249   1          measuring = 0;
  250   1          if(time_us/100<38)                  //判断是否小于38毫秒，大于38毫秒的就是超时，直接调到下面返回0
  251   1          {
  252   2            Distance_mm=(time_us*346)/100;            //计算距离，25°C空气中的音速为346m/s   因为上面的time_end的单位是
             -10微秒，所以要得出单位为毫米的距离结果，还得除以100
C251 COMPILER V5.60.0,  main                                                               13/06/26  12:51:45  PAGE 5   

  253   2          }
  254   1          return Distance_mm;
  255   1      }
